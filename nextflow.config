params {
    samples     = "samples.csv"
    reference   = "reference/GCF_000848505.1_ViralProj14703_genomic.fna"
    outdir      = "results"
    threads     = 8
    memory      = "8 GB"
}

process {
    executor    = 'local'
    cpus        = params.threads
    memory      = params.memory
    maxForks    = 4

    errorStrategy = { task.exitStatus in [143,137,104,134,139] ? 'retry' : 'finish' }
    maxRetries  = 2
}

report {
    enabled = true
    file    = "${params.outdir}/reports/nextflow_report.html"
    overwrite = true
}

trace {
    enabled = true
    file    = "${params.outdir}/reports/trace.txt"
    overwrite = true
}

timeline {
    enabled = true
    file    = "${params.outdir}/reports/timeline.html"
    overwrite = true
}
